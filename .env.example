# ── Supabase ──────────────────────────────────────────────────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (Claude) ─────────────────────────────────────────────────────
# https://console.anthropic.com/keys
# Used for: brief writing, 3-pass QC checks, brand analysis
ANTHROPIC_API_KEY=sk-ant-...

# ── NanaBanana Pro (future — not required to run) ─────────────────────────
# https://nanabanana.pro/dashboard/api
# Brand extraction + 4,000 ad templates. Claude handles brand analysis in the meantime.
# NANABANANA_API_KEY=...
# NANABANANA_API_URL=https://api.nanabanana.pro/v1

# ── Kling AI ──────────────────────────────────────────────────────────────
# https://klingai.com/settings/api
# Used for: PRIMARY image generation — text-to-image + image-to-image for lifestyle/product scenes
KLING_API_KEY=...
KLING_API_SECRET=...

# ── Ideogram ──────────────────────────────────────────────────────────────
# https://ideogram.ai/manage-api
# Used for: ads with overlaid copy — best-in-class text rendering inside images
IDEOGRAM_API_KEY=...

# ── Stability AI ──────────────────────────────────────────────────────────
# https://platform.stability.ai/account/keys
# Used for: high-volume batch generation + product shot inpainting
STABILITY_AI_KEY=sk-...

# ── Remove.bg ─────────────────────────────────────────────────────────────
# https://www.remove.bg/dashboard#api-key
# Used for: automated background removal on every product image before templating
REMOVEBG_API_KEY=...

# ── Creatomate ────────────────────────────────────────────────────────────
# https://creatomate.com/docs/api/rest-api
# Used for: final template-based rendering → 1×1, 4×5, 9×16 export at scale
CREATOMATE_API_KEY=...
# Create 3 templates in your Creatomate dashboard, then add their IDs here:
CREATOMATE_TEMPLATE_1x1=...    # 1080×1080 square template
CREATOMATE_TEMPLATE_4x5=...    # 1080×1350 portrait template
CREATOMATE_TEMPLATE_9x16=...   # 1080×1920 story/reel template

# ── Google Sheets (performance data import) ───────────────────────────────
# Option A — Publish sheet as CSV (File → Share → Publish to web → CSV). No key needed.
# Option B — Service account (base64 encoded JSON key):
# base64 -i key.json | pbcopy
GOOGLE_SERVICE_ACCOUNT_KEY=eyJ...

# ── App Config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
ALLOWED_EMAIL_DOMAIN=hype10agency.com
